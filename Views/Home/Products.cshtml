			<ul class="portfolio-filters isotope-filters" data-aos="fade-up" data-aos-delay="100">
				<li data-filter="*" class="@(string.IsNullOrEmpty(selectedCategory) ? "filter-active" : "")">All</li>
				<li data-filter=".filter-laptops" class="@(selectedCategory == "laptops" ? "filter-active" : "")">Laptops</li>
				<li data-filter=".filter-mobile-phones" class="@(selectedCategory == "mobile-phones" ? "filter-active" : "")">Mobile Phones</li>
				<li data-filter=".filter-tablets" class="@(selectedCategory == "tablets" ? "filter-active" : "")">Tablets</li>
				<li data-filter=".filter-headphones" class="@(selectedCategory == "headphones" ? "filter-active" : "")">Headphones</li>
				<li data-filter=".filter-gaming-consoles" class="@(selectedCategory == "gaming-consoles" ? "filter-active" : "")">Gaming Consoles</li>
				<li data-filter=".filter-computer-accessories" class="@(selectedCategory == "computer-accessories" ? "filter-active" : "")">Computer Accessories</li>
			</ul>


			<div class="row gy-4 isotope-container" data-aos="fade-up" data-aos-delay="200">

				@foreach (var product in Model)
				{
					var imageUrl = product.ProductImages.FirstOrDefault()?.ImageUrl ?? "No Image";
					var categoryClass = "filter-" + (product.Category?.Name?.ToLower().Replace(" ", "-") ?? "uncategorized");

								<div class="col-lg-4 col-md-6 portfolio-item isotope-item @categoryClass">
									<div class="portfolio-content h-100 products">
										<a href="@imageUrl" data-gallery="portfolio-gallery" class="glightbox">

											<div style="height: 250px; display: flex; justify-content: center; align-items: center; background-color: #f9f9f9;">
												<img src="@Url.Content(imageUrl)" class="img-fluid" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="@product.Name" />
											</div>

										</a>
										<div class="portfolio-info">
											<h4><a href="#" title="More Details">@product.Name</a></h4>
											<p>@product.ShortDescription</p>
											<p><strong>Price:</strong> $@product.CurrentPrice</p>
											<p><strong>Brand:</strong> @product.Brand?.Name</p>

											<form asp-controller="Cart" asp-action="AddToCart" method="post">
												<input type="hidden" name="productId" value="@product.Id" />
												<input type="number" name="quantity" value="1" min="1" style="width: 45px;" />
												<button type="submit" class="btn btn-primary mt-2">Add to Cart</button>
											</form>
										</div>

									</div>
								</div>

								<!-- End Portfolio Item -->
				}<!-- End Portfolio Item -->
			</div>
		</div>

	</div>

</section><!-- /Portfolio Section -->

