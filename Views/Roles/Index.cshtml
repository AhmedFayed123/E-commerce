@model IEnumerable<IdentityRole>

@{
	ViewData["Title"] = "Roles";
}
<div class="container" id="index">
	<h1>Roles</h1>

	<table class="table table-striped table-bordered mt-4">
		<thead>
			<tr class="bg-primary text-white">
				<th>Id</th>
				<th>Role Name</th>
			</tr>
		</thead>
		<tbody>
			@foreach(var role in Model)
			{
			<tr>
				<td>@role.Id</td>
				<td>@role.Name</td>
			</tr>
			}
		</tbody>
	</table>
</div>