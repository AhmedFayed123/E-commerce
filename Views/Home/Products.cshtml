@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@model List<Product>
@{
	var selectedCategory = HttpContextAccessor.HttpContext?.Request.Query["category"].ToString();
	var defaultFilter = !string.IsNullOrEmpty(selectedCategory)
		? ".filter-" + selectedCategory.ToLower().Replace(" ", "-").Replace("&", "").Replace(",", "").Replace(".", "")
		: "*";
}


<section id="products" class="portfolio section">
	<link href="~/assets/css/mystyle.css" rel="stylesheet">
	<!-- Section Title -->
	<div class="container section-title" data-aos="fade-up">
		<h2>Products</h2>
		<p>Browse our curated product selection: cutting-edge tech, quality brands, and unbeatable deals!</p>
	</div><!-- End Section Title -->

	<div class="container">

		<div class="isotope-layout" data-default-filter="@defaultFilter" data-layout="masonry" data-sort="original-order">
