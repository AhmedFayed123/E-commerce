<body class="index-page">

    <header id="header" class="header d-flex align-items-center fixed-top">
        <div class="container-fluid container-xl position-relative d-flex align-items-center">

            <a href="/Home/Index" class="logo d-flex align-items-center me-auto">
                <!-- Uncomment the line below if you also wish to use an image logo -->
                <!-- <img src="~/assets/img/logo.png" alt=""> -->
                <h1 class="sitename">TechXpress</h1>
            </a>

            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a href="/Home/Index" class="active">Home</a></li>
                    <li><a href="/Home/Categories#categories">Categories</a></li>
                    <li><a href="/Home/Products#products">Products</a></li>
                    <li><a href="/Categories/Index#index">Categories CRUD</a></li>
                    <li><a href="/Products/Index#indexx">Products CRUD</a></li>
                    <li><a href="/Cart/Index#indexxx">Cart</a></li>
                    <li><a href="/Orders/Index#indexxxx">Orders</a></li>

